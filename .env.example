# Application
APP_ENV=production
APP_NAME=fraud-detection-engine
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_SECRET_KEY=change-me-in-production-use-32-char-secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Model
MODEL_PATH=./models_store/ensemble_model.joblib
FEATURE_PIPELINE_PATH=./models_store/feature_pipeline.joblib
FRAUD_THRESHOLD=0.5
HIGH_RISK_THRESHOLD=0.8

# Monitoring
DRIFT_REFERENCE_PATH=./models_store/reference_data.parquet
DRIFT_CHECK_INTERVAL=3600
PROMETHEUS_PORT=9090

# Data Generation
SYNTHETIC_N_TRANSACTIONS=500000
SYNTHETIC_FRAUD_RATE=0.015
RANDOM_SEED=42
