{
  "title": "Fraud Detection Engine",
  "uid": "fraud-engine-v1",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Transactions / Second",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(transactions_processed_total[1m])",
        "legendFormat": "TPS"
      }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":50},{"color":"red","value":200}] } } }
    },
    {
      "id": 2,
      "title": "Total Fraud Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(fraud_alerts_total)",
        "legendFormat": "Alerts"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 3,
      "title": "P95 Inference Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, rate(model_inference_latency_seconds_bucket[5m])) * 1000",
        "legendFormat": "p95 ms"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":50},{"color":"red","value":200}] } } }
    },
    {
      "id": 4,
      "title": "Model Drift Detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "feature_drift_detected",
        "legendFormat": "Drift"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{"type":"value","options":{"0":{"text":"No Drift","color":"green"},"1":{"text":"DRIFT!","color":"red"}}}] } }
    },
    {
      "id": 5,
      "title": "Fraud Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(fraud_score_bucket[5m])",
        "legendFormat": "{{le}}"
      }]
    },
    {
      "id": 6,
      "title": "Inference Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(model_inference_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, rate(model_inference_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(model_inference_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Alerts by Risk Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(fraud_alerts_total{risk_level=\"CRITICAL\"}[1m])", "legendFormat": "CRITICAL" },
        { "datasource": "Prometheus", "expr": "rate(fraud_alerts_total{risk_level=\"HIGH\"}[1m])", "legendFormat": "HIGH" },
        { "datasource": "Prometheus", "expr": "rate(fraud_alerts_total{risk_level=\"MEDIUM\"}[1m])", "legendFormat": "MEDIUM" },
        { "datasource": "Prometheus", "expr": "rate(fraud_alerts_total{risk_level=\"LOW\"}[1m])", "legendFormat": "LOW" }
      ]
    }
  ]
}
